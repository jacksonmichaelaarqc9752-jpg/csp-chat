# Use the project root URL, not the REST endpoint.
# Correct: https://your-project-ref.supabase.co
# Wrong:   https://your-project-ref.supabase.co/rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI provider keys are entered by the user in Settings and saved to localStorage.
# Do not add AI_API_KEY to Vercel for BYOK trial mode.
EMBEDDING_MODEL=text-embedding-3-small
PROMPT_DEBUG=false
